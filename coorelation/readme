import pandas as pd
import os
import glob

# =========================
# 1. LOAD OIL DATA
# =========================

cl = pd.read_csv("CL=F_historical.csv")
bz = pd.read_csv("BZ=F_historical.csv")

# Detect date column (Yahoo usually: Date)
cl["Date"] = pd.to_datetime(cl.iloc[:, 0])
bz["Date"] = pd.to_datetime(bz.iloc[:, 0])

cl = cl[["Date", "Close"]].rename(columns={"Close": "CL_Close"})
bz = bz[["Date", "Close"]].rename(columns={"Close": "BZ_Close"})

# =========================
# 2. LOAD STOCK FILES
# =========================

folder = "stock_data"
files = glob.glob(os.path.join(folder, "*_historical.csv"))

print(f"Found {len(files)} stock files")

results = []

# =========================
# 3. LOOP THROUGH STOCKS
# =========================

for file in files:
    try:
        ticker = os.path.basename(file).split("_")[0]

        df = pd.read_csv(file)

        # Detect date column
        df["Date"] = pd.to_datetime(df.iloc[:, 0])

        df = df[["Date", "Close"]].rename(columns={"Close": "Stock_Close"})

        # =========================
        # 4. MERGE WITH OIL DATA
        # =========================
        merged = df.merge(cl, on="Date", how="inner").merge(bz, on="Date", how="inner")

        if merged.empty:
            print(f"⚠️ No overlap for {ticker}")
            continue

        # =========================
        # 5. RETURNS (IMPORTANT)
        # =========================
        merged["Stock_ret"] = merged["Stock_Close"].pct_change()
        merged["CL_ret"] = merged["CL_Close"].pct_change()
        merged["BZ_ret"] = merged["BZ_Close"].pct_change()

        merged = merged.dropna()

        # =========================
        # 6. CORRELATIONS
        # =========================
        corr_cl = merged["Stock_ret"].corr(merged["CL_ret"])
        corr_bz = merged["Stock_ret"].corr(merged["BZ_ret"])

        results.append({
            "Ticker": ticker,
            "Corr_WTI_CL=F": corr_cl,
            "Corr_Brent_BZ=F": corr_bz,
            "Data_Points": len(merged)
        })

        print(f"✔ {ticker} done")

    except Exception as e:
        print(f"❌ Error {file}: {e}")

# =========================
# 7. FINAL RESULTS TABLE
# =========================

result_df = pd.DataFrame(results)

result_df = result_df.sort_values("Corr_WTI_CL=F", ascending=False)

display(result_df)

# =========================
# 8. SAVE OUTPUT
# =========================

result_df.to_csv("oil_stock_correlation_results.csv", index=False)

print("\nSaved: oil_stock_correlation_results.csv")
